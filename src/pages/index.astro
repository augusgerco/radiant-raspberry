---
import PasswordGenerator from "../components/PasswordGenerator.astro";
import FeatureCard from "../components/FeatureCard.astro";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Generador de Contraseñas</title>

<nav>
  <span class="nav-title">🔐 Password Generator</span>
  <span id="themeToggle" class="theme-btn">🌙</span>
</nav>

<!-- SECCION 1 -->

<section class="hero">
	<h1 id="title" class="glow-title" data-text="Generador de Contraseñas Seguras">
  Generador de Contraseñas Seguras
	</h1>
	<p>Crea contraseñas fuertes para proteger tus cuentas</p>
</section>

<!-- SECCION 2 APP -->

<PasswordGenerator />

<!-- SECCION 3 INFO -->

<section class="features">
	<FeatureCard
		icon="🔒"
		title="Seguro"
		text="Genera contraseñas difíciles de hackear."
	/>

	<FeatureCard
		icon="⚡"
		title="Rápido"
		text="Crea contraseñas en un solo clic."
	/>

	<FeatureCard
		icon="📱"
		title="Responsive"
		text="Funciona en celular y computadora."
	/>
</section>

<footer>Hecho por @augusgerco</footer>

<style>
	body {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		background: linear-gradient(135deg, #1a1a2e, #16213e);
		color: white;
	}

	/* NAVBAR */

	nav {
		position: relative;
		padding: 20px;
		font-weight: bold;
		letter-spacing: 1px;
		text-align: center;
	}

/* título centrado */
	.nav-title {
		display: inline-block;
	}

/* botón fijo a la derecha */
	.theme-btn {
		position: absolute;
		right: 30px;
		cursor: pointer;
		font-size: 20px;
	}

	.theme-btn{
		cursor:pointer;
		font-size:20px;
		transition:0.2s;
	}

	.theme-btn:hover{
		transform:scale(1.2);
	}
	

	/* HERO */

	.hero {
		text-align: center;
		padding: 60px 20px;
	}

	.hero h1 {
		font-size: 40px;
		margin-bottom: 10px;
	}

	.glow-title{
		line-height: 1.3;
		color: white;
		position: relative;
		display: inline-block; /* CLAVE */
	}

	/* capa de brillo */
	.glow-title::after{
		content: attr(data-text);
		position: absolute;
		inset: 0; /* en vez de left/top */

		display: flex;
		align-items: center;
		justify-content: center;

		background: radial-gradient(
			circle at var(--x, 50%) var(--y, 50%),
			rgba(0,255,255,0.9),
			rgba(0,200,255,0.6),
			transparent 40%
		);

		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;

		opacity: 0;
		transition: opacity 0.2s;
		pointer-events: none;
	}

	.glow-title:hover::after{
		opacity: 1;
	}

	.glow-title::after{
		transition: opacity 0.2s, background-position 0.1s;
	}

	/* GENERATOR CARD */

	.generator {
		display: flex;
		justify-content: center;
		padding: 40px;
	}

	.card {
		background: #0f3460;
		padding: 40px;
		border-radius: 15px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
		width: 350px;
		text-align: center;
	}

	.password {
		font-size: 20px;
		background: #16213e;
		padding: 10px;
		border-radius: 8px;
		margin-bottom: 20px;
		word-break: break-all;
	}

	/* BUTTON */

	button {
		background: #e94560;
		border: none;
		padding: 12px 20px;
		border-radius: 8px;
		color: white;
		font-weight: bold;
		cursor: pointer;
		transition: 0.2s;
	}

	button:hover {
		background: #ff2e63;
		transform: scale(1.05);
	}

	/* FEATURES */

	.features {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 20px;
		padding: 60px;
	}

	.feature {
		background: #0f3460;
		padding: 20px;
		border-radius: 10px;
		text-align: center;
	}

	/* FOOTER */

	footer {
		text-align: center;
		padding: 30px;
		opacity: 0.7;
	}

	/* RESPONSIVE */

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 28px;
		}

		.card {
			width: 90%;
		}

		.features {
			padding: 30px;
		}
	}

	body.light{
		background: linear-gradient(135deg, #e6e9f0, #d1d9e6);
		color: #1a1a1a;
	}

	body.light .glow-title {
  		color: #1a1a1a; /* negro/gris oscuro */
	}

	body.light .card{
		background: #ffffff;
		color: #111;
	}

	body.light .feature{
		background: #ffffff;
		color: #111;
	}

	body.light .password-container{
		background: #e0e0e0;
		color: #111;
	}
	
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {

  // ===== THEME TOGGLE =====
  const toggle = document.getElementById("themeToggle")

  toggle.addEventListener("click", () => {
    document.body.classList.toggle("light")

    if(document.body.classList.contains("light")){
      toggle.innerText = "☀️"
      localStorage.setItem("theme", "light")
    } else {
      toggle.innerText = "🌙"
      localStorage.setItem("theme", "dark")
    }
  })

  const savedTheme = localStorage.getItem("theme")

  if(savedTheme === "light"){
    document.body.classList.add("light")
    toggle.innerText = "☀️"
  }

  // ===== GLOW TITLE =====
  const title = document.getElementById("title")

  function updateGlow(e){
    const rect = title.getBoundingClientRect()

    const x = e.clientX - rect.left
    const y = e.clientY - rect.top

    title.style.setProperty("--x", x + "px")
    title.style.setProperty("--y", y + "px")
  }

  title.addEventListener("mousemove", updateGlow)

  title.addEventListener("mouseleave", () => {
    title.style.setProperty("--x", "50%")
    title.style.setProperty("--y", "50%")
  })

})
</script>
