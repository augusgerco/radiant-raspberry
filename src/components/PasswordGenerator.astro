<section class="generator">
  <div class="card">
    <div class="password-container">
      <span id="password" class="password-text">
        Haz clic para generar
      </span>
    
      <span onclick="toggleVisibility()" class="eye-btn">
        👁️
      </span>
    </div>

    <button onclick="generatePassword()"> Generar contraseña </button>

    <button onclick="copyPassword()" class="copy-btn">
      Copiar contraseña
    </button>
  </div>
</section>

<style>
  .generator {
    display: flex;
    justify-content: center;
    padding: 40px;
  }

  .card {
    background: #0f3460;
    padding: 40px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    width: 350px;
    text-align: center;
  }

  .password-container{
    display:flex;
    align-items:center;
    justify-content:space-between;
    background:#16213e;
    padding:10px;
    border-radius:8px;
    margin-bottom:20px;
  }

  .password-text{
    font-size:20px;
    word-break:break-all;
  }

  .eye-btn{
    cursor:pointer;
    margin-left:10px;
    font-size:18px;
    transition:0.2s;
  }

  .eye-btn:hover{
    transform:scale(1.2);
  }

  .password-text{
  font-size:20px;
  word-break:break-all;
  transition: 0.2s;
}

.password-text.animate{
  transform: scale(1.15);
  color: #e94560;
}

.password-text.animate{
  transform: scale(1.1);
  color: #e94560;
  text-shadow: 0 0 10px rgba(233,69,96,0.7);
}

  /* BOTONES */

  button {
    background: #e94560;
    border: none;
    padding: 12px 20px;
    border-radius: 8px;
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: 0.2s;
  }

  button:hover {
    background: #ff2e63;
    transform: scale(1.05);
  }

  .copy-btn {
    margin-left: 5px;
    background: #533483;
  }

  .copy-btn:hover {
    background: #6f4bb8;
  }

body.light .card {
  background: #f4f6fb;
  color: #1a1a1a;
}

body.light .password-container {
  background: #e0e4ec;
  color: #1a1a1a;
}

body.light button {
  background: #4a6cf7; /* azul más elegante */
}

body.light button:hover {
  background: #3a56c5;
}

body.light .copy-btn {
  background: #6c63ff;
}

body.light .copy-btn:hover {
  background: #554ee0;
}
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {

    let realPassword = ""
    let visible = false

    window.generatePassword = function () {
      const chars =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%&*";

      let password = "";

      for (let i = 0; i < 12; i++) {
        password += chars.charAt(Math.floor(Math.random() * chars.length));
      }

      realPassword = password
      visible = false

      const el = document.getElementById("password")

      el.innerText = ""

      // animación de aparición de puntitos
      let i = 0

      const interval = setInterval(() => {
        el.innerText += "•"
        i++

        if(i >= password.length){
          clearInterval(interval)
        }
      }, 30) // velocidad (más bajo = más rápido)

      // resetear ojo
      document.querySelector(".eye-btn").innerText = "👁️"

      if(window.loadTip){
      window.loadTip()
}
    };

    window.toggleVisibility = function(){

      const el = document.getElementById("password")
      const btn = document.querySelector(".eye-btn")

      if(!realPassword) return

      visible = !visible

      if(visible){
        el.innerText = realPassword
        btn.innerText = "👁️"
      } else {
        el.innerText = "•".repeat(realPassword.length)
        btn.innerText = "👁️"
      }

    }

    window.copyPassword = function () {

      const el = document.getElementById("password")

      // por si no generó nada
      if (!realPassword) {
        el.innerText = "¡Genera para copiar!"
        return
      }

      // esto hace q SIEMPRE copia la real (no los puntitos)
      navigator.clipboard.writeText(realPassword)

      el.innerText = "¡Copiada!"

      setTimeout(() => {
        if(visible){
          el.innerText = realPassword
        } else {
          el.innerText = "•".repeat(realPassword.length)
        }
      }, 1000)
    };

  });
</script>