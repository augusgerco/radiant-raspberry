---
const { icon, title, text } = Astro.props
---

<div class="feature">
  <div class="line"></div>
  <h3>{icon} {title}</h3>
  <p>{text}</p>
<span class="extra">Seguridad asegurada</span>
</div>


<style>
.feature{
  background: #0f3460;
  padding: 20px;
  border-radius: 10px;
  text-align: center;
  transition: 0.3s;
}

.feature:hover{
  transform: translateY(-5px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.6);
}

.feature h3{
  font-size: 22px;
  margin-bottom: 10px;
}

.line{
  height: 3px;
  width: 40px;
  margin: 0 auto 10px;
  border-radius: 5px;
  background: linear-gradient(90deg, #00cfff, #00fff2);
}

.extra{
  display:block;
  margin-top:10px;
  font-size:12px;
  opacity:0.7;
}

.feature{
  background: linear-gradient(145deg, #0f3460, #16213e);
}

.feature{
  animation: fadeUp 0.6s ease;
}

@keyframes fadeUp{
  from{
    opacity:0;
    transform: translateY(20px);
  }
  to{
    opacity:1;
    transform: translateY(0);
  }
}

body.light .feature {
  background: #f4f6fb;
  color: #1a1a1a;
}

body.light .feature p {
  opacity: 0.75;
}
</style>